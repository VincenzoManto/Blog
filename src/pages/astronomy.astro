  <section>
    <h3>Minor Planet Discoveries</h3>
    <div class="card">
      {minorPlanets.length > 0 ? (
        <div style="overflow-x: auto;">
          <table>
            <thead>
              <tr>
                <th>Subject ID</th>
                <th>Designation</th>
                <th>Category</th>
                <th>Link</th>
				<th>Images</th>
              </tr>
            </thead>
            <tbody>
              {minorPlanets.map((planet: any, i: number) => (
                <tr>
                  <td>{planet['Subject ID']}</td>
                  <td>{planet['Designation']}</td>
                  <td>{planet['Category']}</td>
                  <td>
                    {planet['Link'] ? <a href={planet['Link']} target="_blank">MPEC</a> : <span style="color: #aaa;">N/A</span>}
					<a href={`https://www.zooniverse.org/projects/fulsdavid/the-daily-minor-planet/talk/subjects/${planet['Subject ID']}`} target="_blank" style="margin-left: 1rem; font-size: 0.9rem; color: var(--color-primary);">View</a>
                  </td>
				  <td>
					<div class="gallery-wrapper">
  <input type="checkbox" id="zoom-trigger" class="zoom-checkbox">
  <label for="zoom-trigger" class="image-gallery">
		  {planet && planet.Thumbnails ? (
			planet.Thumbnails.map((thumb: string, index: number) => (
			  <img key={index} src={thumb} alt={`Thumbnail ${index + 1}`} style="max-width: 100%; margin-bottom: 1rem;" />
			))
		  ) : (
			<p>No images available.</p>
		  )}
		    </label>
		</div>
				  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="error-message">Nothing found yet in the minor planets log.</div>
      )}
    </div>
  </section>
</Layout>
