---
import Layout from '../layouts/Layout.astro';
import { getMinorPlanetData, getZooniverseDiscussions, getZooniverseComments } from '../lib/api';

const minorPlanets = await getMinorPlanetData();
const discussions = await getZooniverseDiscussions(6403);
let latestMentions = [];
let discussionTitle = "";

if (discussions.length > 0) {
	// Find latest result discussion
	const resultDisc = discussions.find((d: any) => d.title.toLowerCase().includes('result'));
	if (resultDisc) {
		discussionTitle = resultDisc.title;
		const comments = await getZooniverseComments(resultDisc.id);
		// Parse comments to find mentions.
		// Usually the first comment has the table
		if (comments.length > 0) {
			const body = comments[0].body;
			const lines = body.split('\n');
			for (const line of lines) {
				if (line.toLowerCase().includes('manto') || line.toLowerCase().includes('vincenzo')) {
					latestMentions.push(line);
				}
			}
		}
	}
}

// Function to extract subject ID from a Zooniverse text line
function extractSubjectId(line: string) {
	const match = line.match(/\b(\d{8,9})\b/);
	return match ? match[1] : null;
}
---

<Layout title="Astronomy">

  <h2 style="margin-bottom: 2.5rem;">Astronomy Contributions</h2>
  <p>
    Vincenzo Manto contributed in the discovery of {minorPlanets.length} minor planets and asteroids as discoverer or measurer.
  </p>
